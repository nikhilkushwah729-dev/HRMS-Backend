<!DOCTYPE html>
<html>
<head>
    <style>
        .container { font-family: sans-serif; padding: 20px; color: #333; }
        .code { font-size: 24px; font-weight: bold; color: #4338ca; letter-spacing: 2px; }
    </style>
</head>
<body>
    <div class="container">
        <h2>Hello {{ user.firstName }},</h2>
        <p>Your verification code for HRMS Login is:</p>
        <p class="code">{{ code }}</p>
        <p>This code will expire in 10 minutes.</p>
        <p>If you did not request this code, please ignore this email.</p>
    </div>
</body>
</html>
