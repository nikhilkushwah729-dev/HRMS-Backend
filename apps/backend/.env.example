TZ=UTC
PORT=3333
HOST=localhost
APP_URL=http://${HOST}:${PORT}
LOG_LEVEL=info
APP_KEY=
NODE_ENV=development
SESSION_DRIVER=cookie

#--------------------------------------------------------------------
# Mail / OTP delivery
#--------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SECURE=false
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=HRMS

#--------------------------------------------------------------------
# Social Login
#--------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3333/api/auth/google/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:3333/api/auth/microsoft/callback
FIREBASE_API_KEY=

#--------------------------------------------------------------------
# CORS (configure allowed origins for API access)
#--------------------------------------------------------------------
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000

#--------------------------------------------------------------------
# Cloudinary media uploads
#--------------------------------------------------------------------
# Use either CLOUDINARY_URL or the 3 split values below.
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

#--------------------------------------------------------------------
# Frontend and Billing
#--------------------------------------------------------------------
FRONTEND_URL=http://localhost:4200
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Legacy external billing bridge
LEGACY_BILLING_BASE_URL=http://192.168.29.231:3333/v3
LEGACY_BILLING_APP_NAME=ubiAttendance
LEGACY_BILLING_PLAN_BASE_AMOUNT=3000
