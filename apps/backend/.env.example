CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

#--------------------------------------------------------------------
# Frontend and Billing
#--------------------------------------------------------------------
FRONTEND_URL=http://localhost:4200
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Legacy external billing bridge
LEGACY_BILLING_BASE_URL=http://192.168.29.231:3333/v3
LEGACY_BILLING_APP_NAME=ubiAttendance
LEGACY_BILLING_PLAN_BASE_AMOUNT=3000
